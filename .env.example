# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AIRTABLE_ACCESS_TOKEN: Your Airtable Personal Access Token.
VITE_AIRTABLE_ACCESS_TOKEN=""

# AIRTABLE_BASE_ID: The ID of your Airtable Base.
VITE_AIRTABLE_BASE_ID=""

# AIRTABLE_TABLE_ID: The ID of your Events table.
VITE_AIRTABLE_TABLE_ID=""

# AIRTABLE_MUSIC_TABLE_ID: The ID of your Music/Discography table.
VITE_AIRTABLE_MUSIC_TABLE_ID=""

# Optional: Table IDs for directories if they differ from defaults
VITE_AIRTABLE_VENUE_TABLE_ID="Venue Directory"
VITE_AIRTABLE_ARTIST_TABLE_ID="Artist Directory"
VITE_AIRTABLE_CONTROL_TABLE_ID="Control Table"
VITE_AIRTABLE_MASTER_VIDEO_LIST_TABLE_ID="Master Video List"
